---
import Base from '../layouts/Base.astro';

const projects = [
  {
    name: 'Savage Software',
    url: 'https://savagesoftware.dev',
    status: 'active',
    desc: 'Personal hub — History, tools, and writings.',
    icon: '⟨savage/⟩'
  },
  {
    name: 'CyberLab',
    url: 'https://cyberlab.biz',
    status: 'active',
    desc: 'Advanced cybersecurity research powered by AI agents.',
    icon: '🛡️'
  },
  {
    name: 'SoftLab',
    url: 'https://softlab.live',
    status: 'active',
    desc: 'AI agents virtual lab — Multi-agent demos and LLM evaluation.',
    icon: '🤖'
  },
  {
    name: 'DemoCenter',
    url: 'https://democenter.dev',
    status: 'active',
    desc: 'Developer cloud platform with interactive sandboxes.',
    icon: '⚡'
  },
  {
    name: 'Apòstols',
    url: 'https://apostols.org',
    status: 'preserved',
    desc: 'The Apòstols — Unix Cult Est. 1987. Preserved as digital heritage.',
    icon: '✝️'
  },
  {
    name: 'This Site',
    url: 'https://murgo.org',
    status: 'active',
    desc: 'Murgo.org — The hub that connects everything.',
    icon: '◈'
  }
];
---

<Base title="Projects | Murgo.org">
  <section class="projects-hero">
    <div class="container">
      <h1>Projects</h1>
      <p>All digital properties managed by the Murgo family and Savage Software AI agents.</p>
    </div>
  </section>

  <section class="projects-list">
    <div class="container">
      <div class="projects-grid">
        {projects.map((project) => (
          <a href={project.url} target="_blank" class="project-card">
            <div class="project-icon">{project.icon}</div>
            <div class="project-info">
              <h3>{project.name}</h3>
              <p>{project.desc}</p>
              <span class={`project-status ${project.status}`}>
                {project.status === 'active' ? '● Active' : '◎ Preserved'}
              </span>
            </div>
            <div class="project-arrow">→</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="projects-info">
    <div class="container">
      <div class="info-card">
        <h3>🤖 AI-Operated Company</h3>
        <p>
          All these projects are increasingly operated and maintained by AI agents 
          through Paperclip. The agents manage tasks, updates, and research 
          autonomously while humans provide direction.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .projects-hero {
    padding: 4rem 0 2rem;
    text-align: center;
  }

  .projects-hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .projects-hero p {
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .projects-list {
    padding: 3rem 0;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .project-card {
    display: grid;
    grid-template-columns: 60px 1fr 40px;
    gap: 1.5rem;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.3s;
  }

  .project-card:hover {
    border-color: var(--accent-blue);
    transform: translateX(4px);
  }

  .project-icon {
    font-size: 2rem;
    text-align: center;
  }

  .project-info h3 {
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }

  .project-info p {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .project-status {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .project-status.active {
    color: var(--accent-green);
  }

  .project-status.preserved {
    color: var(--accent-orange);
  }

  .project-arrow {
    color: var(--text-muted);
    font-size: 1.2rem;
  }

  .projects-info {
    padding: 2rem 0 4rem;
  }

  .info-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .info-card h3 {
    margin-bottom: 1rem;
  }

  .info-card p {
    color: var(--text-secondary);
    line-height: 1.7;
  }
</style>
