---
import Base from '../layouts/Base.astro';

const tools = [
  {
    id: 'bbdotbas',
    name: 'BB.BAS',
    year: '1988',
    category: 'MSX / Blue Boxing',
    platform: 'MSX BASIC · AY-3-8910 PSG',
    summary: 'A BlueBox program for MSX that generated Spanish R2/CCITT multifrequency signaling tones through the AY-3-8910 PSG chip. Written by Savage / The Phreaker for Apostols in 1988.',
    highlights: [
      'Implements full R2 MF digit table: 700+900, 700+1100, 900+1100, 700+1300, 900+1300, 1100+1300 Hz pairs.',
      'Includes control tones: Fd=2500 Hz (seizure), Fd\'=3825 Hz (alt disconnect), 2600 Hz (US/intl trunk), Fc=1700 Hz (acknowledge).',
      'Direct PSG register writes from BASIC: SOUND 0/1 for channel A, SOUND 2/3 for channel B, formula INT(111861!/Hz).',
      'Interactive key-driven interface — press 0-9 to dial MF digits, A-D for control tones, SPACE for silence.'
    ],
    snippet: `10 REM ==========================================
20 REM  BB.BAS - BlueBox for MSX
30 REM  by |savage| / The Phreaker
40 REM  (c) 1988 Apostols
50 REM ==========================================
60 REM  Generates MF tones via PSG (AY-3-8910)
70 REM  for educational purposes only.
80 REM ==========================================
100 REM Spanish R2/CCITT MF Frequency pairs (Hz)
110 REM  700+900=1  700+1100=2  900+1100=3
120 REM  700+1300=4 900+1300=5  1100+1300=6
130 REM  700+900=7  700+1100=8  900+1100=9
140 REM  1300+700=10(0)
150 REM Fd  = 2500 Hz (disconnect/seizure)
155 REM Fd' = 3825 Hz (alt disconnect)
150 REM Fd  = 2600 Hz (disconnect/international trunk)
160 REM Fc  = 1700 Hz (control/acknowledge)

200 SCREEN 0:WIDTH 40:COLOR 2,0,0:CLS
210 PRINT "========================================="
220 PRINT "  BB.BAS - BlueBox for MSX v1.0"
230 PRINT "  by The Phreaker"
250 PRINT "========================================="
270 PRINT "  [0]-[9] Dial MF digits (R2)"
280 PRINT "  [A]     Fd  2500 Hz (disconnect)"
290 PRINT "  [B]     Fd' 3825 Hz (alt disconnect)"
300 PRINT "  [C]     Fd' 2600 Hz (US/intl trunk)"
305 PRINT "  [D]     Fc  1700 Hz (control)"
310 PRINT "  [SPACE] Silence  [ESC] Quit"
350 PRINT "-----------------------------------------"
360 REM Main loop - wait for keypress
400 K$=INKEY$:IF K$="" THEN 400
410 IF K$=CHR$(27) THEN GOTO 900
420 IF K$=" " THEN SOUND 8,0:SOUND 9,0:GOTO 400
430 IF K$>="0" AND K$<="9" THEN D=VAL(K$):GOTO 600
440 IF K$="A" OR K$="a" THEN GOTO 700
450 IF K$="B" OR K$="b" THEN GOTO 750
460 IF K$="C" OR K$="c" THEN GOTO 830
465 IF K$="D" OR K$="d" THEN GOTO 790
470 GOTO 400

500 REM Tone generation subroutine (PSG freq = 111861 / Hz)
550 F1=INT(111861!/F):SOUND 0,F1 AND 255:SOUND 1,F1\\256
570 F2=INT(111861!/G):SOUND 2,F2 AND 255:SOUND 3,F2\\256
580 SOUND 7,&B111100:SOUND 8,15:SOUND 9,15
585 FOR W=1 TO DU:NEXT W
587 SOUND 8,0:SOUND 9,0
588 FOR W=1 TO 50:NEXT W
590 RETURN

610 REM R2 MF digit tones: 1=700+900 2=700+1100 3=900+1100
640 DATA 1300,700,700,900,700,1100,900,1100,700,1300,900,1300
650 DATA 1100,1300,700,900,700,1100,900,1100
660 DU=300:GOSUB 540:PRINT K$;:GOTO 400

700 F=2500:G=2500:DU=600:GOSUB 540:PRINT "[Fd]";:GOTO 400
750 F=3825:G=3825:DU=600:GOSUB 540:PRINT "[Fd']";:GOTO 400
790 F=1700:G=1700:DU=300:GOSUB 540:PRINT "[Fc]";:GOTO 400
830 F=2600:G=2600:DU=600:GOSUB 540:PRINT "[2600]";:GOTO 400

900 SOUND 8,0:SOUND 9,0:PRINT:PRINT "Bye!":END`,
    download: '/tools/bb.bas',
    downloadLabel: 'bb.bas',
    lang: 'basic',
    context: "Spain, 1988. Phone phreaking was a craft built on understanding signaling protocols. R2 (CCITT No. 5) used dual-tone multifrequency pairs to route calls through the PSTN. The AY-3-8910 PSG on MSX hardware made it possible to synthesize these tones in software — no hardware modification needed. This program was a direct consequence of studying the Spanish telephone network's signaling layer."
  },
  {
    id: 'neped',
    name: 'NePED',
    year: '1998',
    category: 'Linux / Network Security',
    platform: 'C · Linux 2.0.x/2.1.x · libc5 & glibc',
    summary: 'Network Promiscuous Ethernet Detector for Linux. Probes a subnet using crafted ARP frames with a bogus destination MAC and flags hosts that respond — revealing they are running in promiscuous mode (i.e., running a packet sniffer).',
    highlights: [
      'Opens a raw SOCK_PACKET socket bound to ETH_P_ARP to capture all ARP traffic on the segment.',
      'Crafts ARP requests with destination MAC F0:06:66:03:13:37 — a non-broadcast address no real card should accept unless in promiscuous mode.',
      'Uses ioctl SIOCGIFHWADDR/SIOCGIFADDR/SIOCGIFNETMASK/SIOCGIFBRDADDR to collect local interface data.',
      'Scans the full subnet range (network+1 to broadcast-1) and reports hosts that reply to frames not addressed to them.'
    ],
    snippet: `/* -----------------------------------------
     Network Promiscuous Ethernet Detector.
      Linux 2.0.x / 2.1.x, libc5 & GlibC
   -----------------------------------------
         (c) 1998 savage@apostols.org
   -----------------------------------------
   Scan your subnet, and detect promiscuous
   linuxes. It really works, not a joke.
   -----------------------------------------
   $Id: neped.c,v 1.4 1998/07/20 22:31:52 savage Exp $ */

struct arp_struct {
  u_char  dst_mac[6];  u_char  src_mac[6];
  u_short pkt_type;    u_short hw_type;
  u_short pro_type;    u_char  hw_len;
  u_char  pro_len;     u_short arp_op;
  u_char  sender_eth[6]; u_char sender_ip[4];
  u_char  target_eth[6]; u_char target_ip[4];
};

/* Open raw ARP socket — requires root */
rec = socket(AF_INET, SOCK_PACKET, htons(ETH_P_ARP));

/* Collect interface info via ioctl */
ioctl(rec, SIOCGIFHWADDR, &if_data);   /* myMAC      */
ioctl(rec, SIOCGIFADDR, &if_data);     /* myIP       */
ioctl(rec, SIOCGIFNETMASK, &if_data);  /* myNETMASK  */
ioctl(rec, SIOCGIFBRDADDR, &if_data);  /* myBROADCAST */

/* Scan every host on the subnet */
for (dip = (myIP & myNETMASK) + 1; dip < myBROADCAST; dip++) {
  /* Bogus dst MAC: F0:06:66:03:13:37
     Non-promisc cards drop this silently.
     Sniffers in promisc mode process & reply. */
  memcpy(arp_pkt.dst_mac, "\\360\\6\\146\\3\\23\\67", 6);
  arp_pkt.arp_op = htons(ARPREQUEST);

  sendto(rec, full_packet, sizeof(struct arp_struct), 0, &from, sizeof(from));
  usleep(50);

  len = recvfrom(rec, full_packet, MAX_PACK_LEN, 0, &from, &from_len);
  if (ntohs(arp_pkt.arp_op) == ARPREPLY
      && ntohl(ip) == myIP
      && (dip - ntohl(sip) >= 0)
      && (dip - ntohl(sip) <= 2)) {
    printf("*> Host %s, %s **** Promiscuous mode detected !!!\\n",
           inetaddr(sip), hwaddr(arp_pkt.sender_eth));
  }
}`,
    download: '/tools/neped.c',
    downloadLabel: 'neped.c',
    lang: 'c',
    context: '1998. The sniffer problem was real: intruders on shared Ethernet segments deployed tcpdump or similar tools to harvest credentials in cleartext. NePED exploited a subtle protocol behavior — promiscuous-mode drivers reply to ARP frames regardless of destination MAC. The tool gave sysadmins a passive way to audit their own networks without installing agents on every host.'
  },
  {
    id: 'queso',
    name: 'QueSO',
    year: '1998',
    category: 'TCP/IP Fingerprinting',
    platform: 'C · Raw sockets · Linux/BSD',
    summary: 'Remote OS fingerprinting tool that inferred the target operating system from its responses to deliberately abnormal TCP packets. Predated nmap\'s OS detection by months, and introduced the configuration-file approach for signature matching.',
    highlights: [
      'Sends 7 crafted TCP packets (SYN, SYN+ACK, FIN, FIN+ACK, SYN+FIN, PSH, SYN+XXX+YYY) to the target.',
      'Observes seq_num presence, ack_num behavior, window size, and response flags for each packet.',
      'Matches the 7-tuple response signature against queso.conf — a database of OS-specific behaviors.',
      'Exploits RFC ambiguity: undefined flag combinations force each TCP/IP stack to expose its own implementation decisions.'
    ],
    snippet: `/***************************************************************
 * Proyecto:    QueSO ( Que Sistema Operativo ?? )
 * Autor:       Jordi Murgo <savage@apostols.org>
 * Descripcion: Determina el tipo de Sistema Operativo de una
 *              maquina concreta a partir del comportamiento
 *              de su pila TCP/IP ante paquetes TCP 'raros'.
 * CVS: $Id: queso.c,v 1.20 1998/09/22 20:35:43 savage Exp $
 ***************************************************************/

/* Packets sent to probe the target:
 *   0 SYN           <- valid SYN, verifies port is LISTEN
 *   1 SYN+ACK       <- illegal on LISTEN port
 *   2 FIN           <- FIN without prior connection
 *   3 FIN+ACK
 *   4 SYN+FIN       <- impossible combo
 *   5 PSH
 *   6 SYN+XXX+YYY   <- XXX & YYY = unused TCP flags
 *
 * Each TCP/IP stack handles undefined flag combos differently.
 * RFC ambiguity = unique fingerprint per OS.
 */

/* checkos() — sends 7 raw TCP packets, collects responses,
   matches the 7-tuple against the queso.conf database */
int checkos(struct sockaddr_in target, short port) {
  /* pkt 4: SYN+FIN — Linux 2.0 replies with SYN+FIN+ACK */
  /* pkt 6: SYN+XXX+YYY — Linux echoes the unknown flags  */
  /* Windows NT: sends RST to everything except SYN       */
  /* Solaris 2.x: unique window sizes give it away        */
}`,
    confSnippet: `;-----------------------------------------------------------
; queso.conf — OS signature database (CVS 1998/09/16)
;              by savage@apostols.org
;-----------------------------------------------------------
; Format: pkt# seq ack window flags
;   seq/ack: 1=present 0=absent -=no reply +n=offset R=random
;   window:  1=any 0=zero x=hex_value -=no reply
;   flags:   S=SYN R=RST A=ACK F=FIN P=PSH X=xxx Y=yyy U=URG
;-----------------------------------------------------------

* Linux 2.0.35 to 2.0.9999 :)
0 1 1 7FE0 SA
1 0 0 0    R
2 - - -    -
3 0 0 0    R
4 1 1 7FE0 SFA
5 - - -    -
6 1 1 7FE0 SA

* Linux 1.3.xx, 2.0.0 to 2.0.34
0 1 1 1    SA
1 0 0 0    R
2 - - -    -
3 0 0 0    R
4 1 1 1    SFA
5 - - -    -
6 1 1 1    SAXY

* Not Listen, Windoze 95/98/NT
0 0 +1 0   RA
1 0  0 0   R
2 0 +1 0   RA
3 0  0 0   R
4 0 +1 0   RA

* Solaris 2.x
0 1 1 17C0 SA
1 0 0 0    R
2 - - -    -
3 0 0 0    R
4 0 1 0    RA
5 - - -    -
6 0 1 0    RA

* FreeBSD
0 1  1 4000 SA
1 0  0 0    R
2 0  1 0    RA
3 0  0 0    R
4 0  1 0    RA
5 0  1 0    RA
6 0  1 0    RA`,
    download: '/tools/queso-0.980922b-3.zip',
    downloadLabel: 'queso-0.980922b-3.zip',
    lang: 'c',
    context: 'April 1997 – September 1998. QueSO (Spanish: "¿Qué Sistema Operativo?", "What OS?") came from a concrete problem: auditing a network without relying on banners, SNMP, or rpcinfo — all of which are slow, noisy, and require open services. The insight was that TCP\'s RFC left ambiguous cases undefined, meaning every OS would respond to malformed packets in its own way. The signature-database approach in queso.conf became the template that nmap would later adopt for its own OS fingerprinting engine.'
  }
];
---

<Base
  title="Tools Museum | Murgo.org"
  description="Original Apostols-era tools by Jordi Murgó 'Savage': BB.BAS (1988), NePED (1998), and QueSO (1998) — with technical context, real source code, and downloadable artifacts."
>
  <section class="museum-hero">
    <div class="container">
      <p class="eyebrow">Archive / Tools Museum</p>
      <h1>Original tools from the Apostols years</h1>
      <p class="hero-copy">
        Real source artifacts from 1988–1998: a phone-signaling synthesizer for MSX,
        a promiscuous-mode detector, and the OS fingerprinting tool that predated nmap.
        Each file is available in its original form.
      </p>
      <div class="hero-meta">
        <span class="meta-tag">3 tools</span>
        <span class="meta-sep">·</span>
        <span class="meta-tag">1988 – 1998</span>
        <span class="meta-sep">·</span>
        <span class="meta-tag">Primary sources</span>
      </div>
    </div>
  </section>

  <section class="toc-section">
    <div class="container">
      <nav class="toc-nav" aria-label="Tools index">
        {tools.map((tool) => (
          <a href={`#${tool.id}`} class="toc-link">
            <span class="toc-year">{tool.year}</span>
            <span class="toc-name">{tool.name}</span>
            <span class="toc-cat">{tool.category}</span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  <section class="museum-grid-section">
    <div class="container museum-grid">
      {tools.map((tool) => (
        <article class="museum-card" id={tool.id}>
          <div class="museum-card-header">
            <div class="header-left">
              <p class="tool-meta">{tool.year} · {tool.platform}</p>
              <h2>{tool.name}</h2>
              <p class="tool-category">{tool.category}</p>
            </div>
            <div class="header-right">
              <span class="artifact-badge">Primary source</span>
              <a href={tool.download} download class="download-btn" aria-label={`Download ${tool.downloadLabel}`}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                {tool.downloadLabel}
              </a>
            </div>
          </div>

          <p class="tool-summary">{tool.summary}</p>

          <ul class="tool-highlights">
            {tool.highlights.map((item) => <li>{item}</li>)}
          </ul>

          <div class="code-block">
            <div class="code-header">
              <span class="code-lang">{tool.lang}</span>
              <span class="code-filename">{tool.downloadLabel}</span>
            </div>
            <pre class="code-sample"><code>{tool.snippet}</code></pre>
          </div>

          {tool.confSnippet && (
            <div class="code-block conf-block">
              <div class="code-header">
                <span class="code-lang">conf</span>
                <span class="code-filename">queso.conf</span>
              </div>
              <pre class="code-sample"><code>{tool.confSnippet}</code></pre>
            </div>
          )}

          <blockquote class="tool-context">
            <p>{tool.context}</p>
          </blockquote>
        </article>
      ))}
    </div>
  </section>

  <section class="museum-notes">
    <div class="container notes-panel">
      <div class="notes-text">
        <p class="eyebrow">Reading the arc</p>
        <h2>From signaling tricks to fingerprinting stacks</h2>
        <p>
          The archive shows a consistent path: low-level curiosity about how systems
          actually behave — at the PSG register level, at the ARP layer, at the TCP
          flag boundary. Each tool came from studying a protocol deeply enough to find
          the edge case that reveals hidden state. That pattern is the point of this page.
        </p>
      </div>
      <div class="notes-timeline">
        <div class="nt-item">
          <span class="nt-year">1988</span>
          <span class="nt-label">BB.BAS — MSX PSG tone synthesis</span>
        </div>
        <div class="nt-connector"></div>
        <div class="nt-item">
          <span class="nt-year">1998</span>
          <span class="nt-label">NePED — ARP promiscuity detection</span>
        </div>
        <div class="nt-connector"></div>
        <div class="nt-item">
          <span class="nt-year">1998</span>
          <span class="nt-label">QueSO — TCP/IP OS fingerprinting</span>
        </div>
      </div>
    </div>
  </section>
</Base>

