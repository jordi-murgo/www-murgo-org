---
import Base from '../layouts/Base.astro';

const timeline = [
  { year: '1982–1987', title: 'Early Systems', desc: 'Commodore, ZX Spectrum, MSX, and early PC experimentation shaped a low-level approach to computing: hardware, protocols, and undocumented behavior.' },
  { year: '1988', title: 'BB.BAS', desc: 'Built BlueBox software for MSX, generating Spanish R2/CCITT multifrequency signaling tones directly through the AY-3-8910 PSG chip. The formula INT(111861/Hz) maps tone frequency to PSG register values.' },
  { year: '1989', title: 'Apòstols Founded', desc: 'Co-founded The Apòstols hacking collective, which became a hub for the Catalan and Spanish underground scene through the 1990s.' },
  { year: '1990–1995', title: 'Underground Research', desc: 'Deep work across phreaking, X.25 exploration, protocol knowledge, and security research inside the Catalan and Spanish underground scene.' },
  { year: '1998', title: 'NePED and QueSO', desc: 'Released NePED — a promiscuous-mode detector using crafted ARP frames — and QueSO, the OS fingerprinting tool that probed TCP/IP stacks with deliberately malformed packets. Both published as open source on apostols.org.' },
  { year: '1999', title: 'EncomIX Founded', desc: 'Co-founded EncomIX ISP, applying the same protocol-level knowledge to infrastructure operations.' },
  { year: '2000', title: 'LleidaNet Founded', desc: 'Co-founded LleidaNet ISP, one of the early independent internet providers in Catalonia.' },
  { year: '2004', title: 'IRC-Hispano', desc: 'Founded IRC-Hispano, one of the largest Spanish-language IRC networks.' },
  { year: '2020–Present', title: 'AI and Security', desc: 'Current work connects the same curiosity about system behavior to AI agents, automation, and practical security research at GFT.' }
];

const tools = [
  {
    name: 'BB.BAS',
    year: '1988',
    desc: 'MSX BlueBox for Spanish R2/CCITT MF signaling. Synthesizes tone pairs via AY-3-8910 PSG using the formula INT(111861/Hz) for register values.',
    icon: '◉',
    href: '/tools#bbdotbas'
  },
  {
    name: 'NePED',
    year: '1998',
    desc: 'Network Promiscuous Ethernet Detector for Linux. Sends crafted ARP frames to bogus MACs and flags hosts that reply — revealing active sniffers.',
    icon: '◎',
    href: '/tools#neped'
  },
  {
    name: 'QueSO',
    year: '1998',
    desc: 'Remote OS fingerprinting through responses to malformed TCP packets (SYN+FIN, SYN+XXX+YYY). Signature-based database approach adopted later by nmap.',
    icon: '◇',
    href: '/tools#queso'
  }
];

const museumSnippets = [
  {
    label: 'BB.BAS · MSX BASIC · 1988',
    lang: 'BASIC',
    excerpt: `10 REM BB.BAS - BlueBox for MSX
40 REM (c) 1988 Apostols
100 REM Spanish R2/CCITT MF Frequency pairs (Hz)
110 REM  700+900=1  700+1100=2  900+1100=3
150 REM Fd  = 2500 Hz (disconnect/seizure)
160 REM Fc  = 1700 Hz (control/acknowledge)
550 F1=INT(111861!/F):SOUND 0,F1 AND 255:SOUND 1,F1\\256
570 F2=INT(111861!/G):SOUND 2,F2 AND 255:SOUND 3,F2\\256
580 SOUND 7,&B111100:SOUND 8,15:SOUND 9,15`
  },
  {
    label: 'NePED · C · 1998',
    lang: 'C',
    excerpt: `/* (c) 1998 savage@apostols.org
 * Bogus dst MAC: F0:06:66:03:13:37
 * Non-promisc cards drop this frame silently.
 * Sniffers in promisc mode process and reply. */
memcpy(arp_pkt.dst_mac, "\\360\\6\\146\\3\\23\\67", 6);
arp_pkt.arp_op = htons(ARPREQUEST);
/* ... */
printf("*> Host %s **** Promiscuous mode detected !!!\\n",
       inetaddr(sip));`
  },
  {
    label: 'QueSO · C · 1998',
    lang: 'C',
    excerpt: `/* Que Sistema Operativo? by savage@apostols.org
 * CVS: $Id: queso.c,v 1.20 1998/09/22 20:35:43 savage Exp $
 *
 * Sends 7 TCP packets with abnormal flag combos.
 * Each TCP/IP stack's RFC-undefined behavior reveals the OS.
 *
 *   0 SYN   1 SYN+ACK   2 FIN   3 FIN+ACK
 *   4 SYN+FIN   5 PSH   6 SYN+XXX+YYY
 *
 * queso.conf entry for Linux 1.x/2.0:
 *   4 1 1 1 SFA   <- pkt#4 gets SYN+FIN+ACK back
 *   6 1 1 1 SAXY  <- pkt#6 echoes unknown flags
 */`
  }
];
---

<Base
  title="Savage - Jordi Murgó | Murgo.org"
  description="Jordi Murgó 'Savage': history, primary-source tools, and the path from Apostols-era protocol experiments to AI security work."
>
  <section class="savage-hero">
    <div class="container">
      <div class="savage-header">
        <div class="savage-image">
          <img src="/images/savage.jpg" alt="Jordi Murgó 'Savage'" onerror="this.style.display='none'">
        </div>
        <div class="savage-intro">
          <span class="savage-tag">⟨savage/⟩</span>
          <h1>Jordi Murgó</h1>
          <p class="savage-aka">aka <strong>"Savage"</strong></p>
          <p class="savage-bio">
            Early Catalan hacker, security researcher, entrepreneur, and AI
            builder. The pattern stays the same across decades: understand the
            protocol, inspect the edge case, and turn that behavior into tools.
          </p>
          <div class="savage-links">
            <a href="https://twitter.com/jordimurgo" target="_blank" rel="noopener">𝕏 @jordimurgo</a>
            <a href="https://linkedin.com/in/jordimurgo/" target="_blank" rel="noopener">LinkedIn</a>
            <a href="mailto:jordi.murgo@gmail.com">Email</a>
            <a href="/tools">Tools Museum</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="history-section">
    <div class="container">
      <h2 class="section-title">History</h2>
      <div class="timeline">
        {timeline.map((item) => (
          <div class="timeline-item">
            <div class="timeline-year">{item.year}</div>
            <div class="timeline-content">
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="tools-section">
    <div class="container">
      <h2 class="section-title">Tools Created</h2>
      <div class="tools-grid">
        {tools.map((tool) => (
          <a href={tool.href} class="tool-card">
            <div class="tool-icon">{tool.icon}</div>
            <h3>{tool.name}</h3>
            <span class="tool-year">{tool.year}</span>
            <p>{tool.desc}</p>
            <span class="tool-cta">View source →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="museum-section">
    <div class="container">
      <div class="museum-intro">
        <div>
          <h2 class="section-title align-left">Source Snippets</h2>
          <p>
            The archive matters because the original files still exist. These are
            real artifacts from the Apostols years, surfaced with enough context
            to show how the ideas actually worked.
          </p>
        </div>
        <a href="/tools" class="museum-cta">Browse full archive →</a>
      </div>
      <div class="snippet-grid">
        {museumSnippets.map((snippet) => (
          <article class="snippet-card">
            <div class="snippet-header">
              <p class="snippet-label">{snippet.label}</p>
              <span class="snippet-lang">{snippet.lang}</span>
            </div>
            <pre><code>{snippet.excerpt}</code></pre>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="current-section">
    <div class="container">
      <h2 class="section-title">Current Work</h2>
      <div class="current-card">
        <h3>Security and AI Specialist at GFT</h3>
        <p>
          Combining decades of security experience with current AI systems work:
          agent orchestration, prompt-injection research, and practical automation
          through Savage Software and the Murgo hub.
        </p>
        <div class="current-badges">
          <span>AI Agents</span>
          <span>Prompt Injection Research</span>
          <span>Cybersecurity</span>
          <span>Open Source</span>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .savage-hero {
    padding: 4rem 0;
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.05) 0%, transparent 100%);
  }

  .savage-header {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .savage-image {
    width: 250px;
    height: 250px;
    border-radius: 12px;
    overflow: hidden;
    border: 2px solid var(--border);
  }

  .savage-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .savage-tag {
    font-family: var(--font-mono);
    color: var(--accent-blue);
    font-size: 0.9rem;
  }

  .savage-intro h1 {
    font-size: 2.5rem;
    margin: 0.5rem 0;
  }

  .savage-aka {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }

  .savage-bio {
    color: var(--text-secondary);
    max-width: 680px;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .savage-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .savage-links a {
    color: var(--accent-blue);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .section-title {
    font-size: 1.8rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .align-left {
    text-align: left;
  }

  .history-section {
    padding: 4rem 0;
  }

  .timeline {
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .timeline-year {
    font-family: var(--font-mono);
    color: var(--accent-blue);
    font-size: 0.9rem;
    text-align: right;
    padding-top: 0.3rem;
  }

  .timeline-content h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .timeline-content p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .tools-section {
    padding: 4rem 0;
    background: var(--bg-secondary);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .tool-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: border-color 0.2s, transform 0.2s;
  }

  .tool-card:hover {
    border-color: var(--accent-blue);
    transform: translateY(-2px);
  }

  .tool-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-blue);
  }

  .tool-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }

  .tool-year {
    font-family: var(--font-mono);
    color: var(--accent-blue);
    font-size: 0.8rem;
  }

  .tool-card p {
    color: var(--text-secondary);
    font-size: 0.88rem;
    margin-top: 1rem;
    line-height: 1.65;
    flex: 1;
  }

  .tool-cta {
    margin-top: 1.25rem;
    font-size: 0.82rem;
    color: var(--accent-blue);
    font-family: var(--font-mono);
  }

  .museum-section {
    padding: 4rem 0;
  }

  .museum-intro {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .museum-intro p {
    color: var(--text-secondary);
    max-width: 720px;
    line-height: 1.75;
  }

  .museum-cta {
    color: var(--accent-blue);
    text-decoration: none;
    white-space: nowrap;
    font-size: 0.9rem;
  }

  .snippet-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .snippet-card {
    background: #06070b;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
  }

  .snippet-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .snippet-label {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .snippet-lang {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--accent-blue);
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.25);
    border-radius: 4px;
    padding: 0.15rem 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .snippet-card pre {
    overflow-x: auto;
    font-size: 0.78rem;
    line-height: 1.6;
  }

  .current-section {
    padding: 4rem 0;
  }

  .current-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .current-card h3 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
    color: var(--accent-blue);
  }

  .current-card p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .current-badges {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .current-badges span {
    background: var(--bg-secondary);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .savage-header,
    .snippet-grid {
      grid-template-columns: 1fr;
    }

    .savage-header {
      text-align: center;
    }

    .museum-intro {
      flex-direction: column;
      align-items: start;
    }

    .timeline-item {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .timeline-year {
      text-align: left;
      padding-top: 0;
    }
  }
</style>
